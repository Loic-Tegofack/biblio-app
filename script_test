import sqlite3
import os
import random
from datetime import datetime, timedelta
from faker import Faker
from controleurBiblio import Author_Manager, Book_Manager, User_Manager

fake = Faker('fr_FR')

def populate_massive_db():
    db_name = "test.db"

    # Suppression ancienne base
    if os.path.exists(db_name):
        try:
            os.remove(db_name)
        except:
            pass

    # Initialisation managers (créent les tables si ton modèle est correct)
    author_mgr = Author_Manager(db_name)
    book_mgr = Book_Manager(db_name)
    user_mgr = User_Manager(db_name)

    print("🚀 Création d'une base massive en cours...")

    # =========================
    # 1️⃣ Génération Auteurs + Livres
    # =========================
    genres = ["Roman", "Science", "Philosophie", "Histoire", "Politique", "Fantastique", "Drame"]
    etats = ["Neuf", "Excellent", "Bon état", "Acceptable"]

    for i in range(300):
        try:
            titre = fake.sentence(nb_words=4).replace(".", "")
            nom = fake.last_name()
            prenom = fake.first_name()
            naissance = str(random.randint(1940, 2000))
            pays = fake.country()
            annee = str(random.randint(1970, 2024))
            nb_exemplaires = str(random.randint(2, 15))
            genre = random.choice(genres)
            etat = random.choice(etats)

            book_mgr.ajouter_livre(
                titre,
                nom,
                prenom,
                naissance,
                pays,
                etat,
                annee,
                nb_exemplaires,
                genre
            )
        except Exception as e:
            print("Erreur livre :", e)

    print("✅ 300 livres générés.")

    # =========================
    # 2️⃣ Utilisateurs
    # =========================
    for _ in range(150):
        try:
            user_mgr.ajout_utilisateur(
                fake.last_name(),
                fake.first_name(),
                fake.address().replace("\n", " "),
                fake.password(length=12)
            )
        except Exception as e:
            print("Erreur utilisateur :", e)

    print("✅ 150 utilisateurs créés.")

    # =========================
    # 3️⃣ Emprunts massifs
    # =========================
    con = sqlite3.connect(db_name)
    cur = con.cursor()

    today = datetime.now()

    # Création de 200 emprunts
    for _ in range(200):
        livre_id = random.randint(1, 300)
        user_id = random.randint(1, 150)

        date_emprunt = today - timedelta(days=random.randint(1, 60))
        date_retour_prevue = date_emprunt + timedelta(days=14)

        cur.execute("""
            INSERT INTO Emprunt (livre_id, utilisateur_id, date_emprunt, date_retour_prevue)
            VALUES (?, ?, ?, ?)
        """, (
            livre_id,
            user_id,
            date_emprunt.strftime('%Y-%m-%d'),
            date_retour_prevue.strftime('%Y-%m-%d')
        ))

    con.commit()
    con.close()

    print("✅ 200 emprunts générés.")
    print("🏁 Base de données massive prête.")

if __name__ == "__main__":
    populate_massive_db()